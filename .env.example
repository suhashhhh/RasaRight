## Expo public environment variables
## Copy this file to `.env` and adjust values.

# Backend base URL (FastAPI). Use your laptop's IP on the current network.
# Home Wi-Fi example: http://192.168.1.8:8082
# iPhone Personal Hotspot example: http://172.20.10.3:8082
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.8:8082

# Backend PostgreSQL connection string
# Example:
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/rasaright
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/rasaright

